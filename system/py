# FUNCTINGS - GET COMM #
def get_all_commands ():
    comm_files = []
    #
    if BD_EXISTS:
        source = BASE_DIR.rglob("*")
        for item in source:
            if not item.is_file():
                continue
            #
            comm_files.append(str(item))
    else:
        response = requests.get(BDF_API_LINK)
        data = response.json()
        #
        for item in data:
            if item["type"] != "file":
                continue
            #
            comm_files.append(item["name"])
    #
    return comm_files
#
def print_comms (comm_files):
