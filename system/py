# FUNCTINGS - EXCING #
def resolve_target (comm_file):
    command_path = comm_file.replace(":", Var.slash)
    target_maps = [
        f"{command_path}.py",
        command_path,
    ]
    for target in target_maps:
        #print ((REDIC_LINK) + "/" + (target))
        #
        if BD_EXISTS:
            target_f = (REDIC_LINK / target)
            if target_f.exists():
                return target_f
        else:
            target_f = Var.slash.join([
                BD_RAW_LINK,
                target
            ])
            response = requests.get(target_f)
            if response.status_code == 200:
                return target_f
    #
    return None
def execute_target(target_f, extra_args):
    # LOCAL #
    if BD_EXISTS:
        subprocess.run(
            [sys.executable, str(target_f), *extra_args],
            check=True
        )
        return
    #
    # REMOTE #
    response = requests.get(target_f)
    if response.status_code != 200:
        print("Failed download target...")
        return
    #
    with tempfile.NamedTemporaryFile(
        delete=False,
        suffix=".py",
        mode="w",
        encoding="utf-8"
    ) as temp_file:
        temp_file.write(response.text)
        temp_path = temp_file.name
    #
    subprocess.run(
        [sys.executable, temp_path, *extra_args],
        check=True
    )
#
# FUNCTINGS - EXCING #


# FUNCTINGS - FINAL #
def sys_work ():
    #
    comm_files = get_all_commands()
    #
    if len(sys.argv) < 2:
        print_comms(comm_files)
        return
    #
    comm_file = sys.argv[1]
    target_f = resolve_target(comm_file)
    if target_f is None:
        msg_404 = f"Command `{comm_file}` is Not-Found..."
        print(msg_404)
        return
    #
    extra_args = sys.argv[2:]
    execute_target(target_f, extra_args)
