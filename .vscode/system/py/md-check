def render_doc(doc):
    path = doc["path"]
    filename = path.name
    folder = os.path.relpath(path.parent, ROOT_DIR)
    #
    md_status = get_doc_type(doc)
    cek_stat = md_status.replace(pyV["uscor"], pyV["space"])
    #
    print(f"[{cek_stat}] - {filename} -> {folder}")
#
def excheck(docs, filtype=None):
    found = 0
    #
    for doc in docs:
        if filtype and get_doc_type(doc) != filtype:
            continue
        #
        render_doc(doc)
        found += 1
    if found > 0:
        return
    if filtype:
        print((pyV["space"] * 2) +
            ("{404}: Not-Found as Filtered, sorry..."))
        return
    #
    msg_search_404 = "No matching Entry-Docs is found in here..."
        #
    print((pyV["space"] * 2) + (msg_search_404))
    print(ENDED_TASKING)
