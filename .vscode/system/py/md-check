CLI_KEYS = {"base",
    "search","sort",
    "to", }
CLI_FLAGS = {
    "descend", }
CLI_TARGETS = {
    "check", }
#
def parse_arg(args, key):
    prefix = f"{key}="
    for arg in args:
        if arg.startswith(prefix):
            return arg.split(pyV["equal"], 1)[1]
    return None
def normalize_doc_type(value):
    if not value:
        return None
    value = value.strip()
    return next((doc_type for doc_type in VALID_TYPES
        if doc_type.lower() == value.lower()), None, )
#
def validate_args(args):
    validators = {"to": (CLI_TARGETS, "Unknown Target"),
        "sort": (None, None), "search": (None, None),
        "base": (None, None), }
    for arg in args:
        if arg in CLI_FLAGS:
            continue
        if pyV["equal"] not in arg:
            raise ValueError(f"Invalid Argument: {arg}")
        #
        key, value = arg.split(pyV["equal"], 1)
        if key not in CLI_KEYS:
            raise ValueError(f"Unknown Command: {key}")
        #
        valid_values, err = validators.get(key, (None, None))
        if valid_values is not None and value not in valid_values:
            raise ValueError(f"{err}: {value}")
    #
    filter_type = parse_arg(args, "search")
    if filter_type and normalize_doc_type(filter_type) is None:
        raise ValueError(f"Unknown Doc Type: {filter_type}")
#
def read_file(path):
    try:
        return path.read_text(encoding="utf-8")
    except OSError as exc:
        print(f"FILE ERROR: {path} -> {exc}")
        return None
def parse_meta(text, path):
    block = re.search(r"<!--\s*---\s*(.*?)\s*---\s*-->", text, re.S)
    if not block:
        return {}
    #
    try:
        parsed = yaml.safe_load(block.group(1))
    except yaml.YAMLError as exc:
        print(f"YAML ERROR: {path} -> {exc}")
        return {}
    #
    if not isinstance(parsed, dict):
        return {}
    if DEF_SEARCH not in parsed:
        print(f"MISSING KEY [{DEF_SEARCH}]: {path}")
        return {}
    return parsed
#
def resolve_base_dir(args):
    base = parse_arg(args, "base")
    if not base:
        return BASE_DIR
    #
    base_path = Path(base)
    if not base_path.is_absolute():
        base_path = ROOT_DIR / base_path
    return base_path
def scan_docs(base_dir):
    tell_branch = ((pyV["braceL"])
        + (gitD["branch"]) + (pyV["braceR"]))
    docs = []
    #
    if not base_dir.exists():
        get_path = base_dir.as_posix()
        #
        print(f"Now Branch: {tell_branch}")
        print(f"NOT-FOUND in get path: {get_path}")
        return docs
    #
    for path in sorted(base_dir.rglob("*.md")):
        text = read_file(path)
        if text is None:
            continue
        #
        docs.append({
            "meta": parse_meta(text, path),
            "path": path,
        })
    #
    return docs
