# SYSTERMINALS - SORTING #
def parse_sort_args(args):
    mode = VALID_SORT[0]
    order = VALID_ORDER[0]
    #
    if "descend" in args:
        mode = VALID_SORT[-1]
        order = VALID_ORDER[-1]
    #
    value = parse_arg(args, "sort")
    if not value:
        return {"mode": mode, "order": order}
    #
    parts = value.lower().split(pyV["colon"], 1)
    mode = parts[0]
    if len(parts) > 1:
        order = parts[1]
    #
    if mode not in VALID_SORT:
        raise ValueError(f"Unknown Sort: {mode}")
    if order not in VALID_ORDER:
        raise ValueError(f"Unknown Sort Order: {order}")
    return { "mode": mode, "order": order, }
#
def enum_def_bs(items):
    return {
        item: index
        for index, item in enumerate(items)
    }
def build_sorters():
    return {
        "default": enum_def_bs(sorted(VALID_TYPES)),
        "types": enum_def_bs(VALID_TYPES),
    }
#
def get_doc_type(doc):
    doc_type = doc["meta"].get(DEF_SEARCH, UNDEF_TYPE)
    if doc_type not in VALID_TYPES:
        return UNDEF_TYPE
    return doc_type
def get_sort_key(mode, sorters):
    if mode == "type":
        return lambda doc: (
            sorters["types"].get(get_doc_type(doc), 999),
            str(doc["path"]).lower(), )
    if mode == "path":
        return lambda doc: str(doc["path"]).lower()
    if mode == "deff":
        return lambda doc: (
            sorters["default"].get(get_doc_type(doc), 999),
            str(doc["path"]).lower(), )
    return lambda doc: str(doc["path"]).lower()
#
def sort_docs(docs, config, sorters):
    return sorted(docs,
        key=get_sort_key(config["mode"], sorters),
        reverse=(config["order"] == "desc"), )
#
# SYSTERMINALS - SORTING #


# SYSTERMINALS - FILTER #
def build_filter_type(args):
