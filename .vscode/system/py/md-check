def sys_main():
    cli_args = sys.argv[1:]
    #
    try:
        validate_args(cli_args)
        sort_config = parse_sort_args(cli_args)
        filter_type = build_filter_type(cli_args)
        base_dir = resolve_base_dir(cli_args)
    except ValueError as exc:
        print(exc)
        check_args()
        return 1
    #
    if not cli_args:
        check_args()
        return 0
    #
    docs = scan_docs(base_dir)
    docs = sort_docs(docs, sort_config, build_sorters())
    #
    actions = {
        "check": lambda: excheck(docs,
            filter_type), }
    to = parse_arg(cli_args, "to")
    action = actions.get(to)
    #
    if not action:
        print(f"Unknown Target: {to}")
        check_args()
        return 1
    #
    action()
    return 0
