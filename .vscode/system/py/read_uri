# IMPORTS #
import sys
import base64
import re
#
from datetime import datetime
# IMPORTS #


# SYSTEM? - ? #
def parse_arguments (argv):
    if len(argv) < 2:
        raise ValueError("Usage: python read_uri.py <data-uri>")
    return argv[1]
#
def parse_data_uri( data_uri):
    pattern = r'data:(image/\w+);base64,(.+)'
    match = re.match(pattern, data_uri)
    if not match:
        raise ValueError("Format data URI tidak valid")
    #
    mime_type = match.group(1)
    base64_data = match.group(2)
    ext = mime_type.split('/')[-1]
    return ext, base64_data
#
def make_output_filename (ext):
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    return f"output_{timestamp}.{ext}"
#
def save_base64_image (base64_data, filename):
    decoded = base64.b64decode(base64_data)
    with open(filename, "wb") as f:
        f.write(decoded)
    return filename
#
def read_exif_data (filename):
    try:
        from PIL import Image
        from PIL.ExifTags import TAGS
    except ImportError:
        print("⚠️ PIL tidak terinstall (skip EXIF)")
        return
    #
    try:
        with Image.open(filename) as img:
            exif = img._getexif()

        if not exif:
            print("ℹ️ Tidak ada EXIF")
            return

        print("📷 EXIF Data:")
        for tag, value in exif.items():
            print(f"{TAGS.get(tag, tag)}: {value}")
    except Exception:
        print("⚠️ Gagal baca EXIF")
#
# SYSTEM? - ? #


# PRINTING - DISPLAY #
def main ():
    try:
        data_uri = parse_arguments(sys.argv)
        ext, base64_data = parse_data_uri(data_uri)
        filename = make_output_filename(ext)
        save_base64_image(base64_data, filename)
        print(f"✅ File tersimpan: {filename}")
        read_exif_data(filename)
    except ValueError as exc:
        print(f"❌ {exc}")
    except Exception as exc:
        print(f"❌ Gagal decode: {exc}")
#
if __name__ == "__main__":
    main()
# PRINTING - DISPLAY #

