# FUNCTINGS - GET COMM #
def get_all_commands ():
    comm_files = []
    #
    if PD_EXISTS:
        source = PY_DIR.rglob("*")
        for item in source:
            if not item.is_file():
                continue
            #
            comm_files.append(str(item))
    else:
        response = requests.get(FULL_API_LINK)
        if response.status_code != 200:
            reset_unix = int(response.headers["X-RateLimit-Reset"])
            wait_sec = int((reset_unix) - (time.time()))
            #
            print(f"Request failed: {response.status_code}")
            print(response.text)
                #
            print(("API at Limit: ") + (response.headers.get("X-RateLimit-Limit")))
            print(("API remains: ") + (response.headers.get("X-RateLimit-Remaining")))
                #
            print(("Reset at: ") + (response.headers.get("X-RateLimit-Reset")))
            print(f"Reset in {wait_sec} seconds")
            return []
        #
        data = response.json()
        for item in data:
            if item["type"] != "file":
                continue
            #
            comm_files.append(item["name"])
    #
    return comm_files
