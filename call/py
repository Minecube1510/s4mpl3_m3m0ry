def get_all_commands ():
    comm_files = []
    #
    if PY_DIR.exists():
        #source = BASE_DIR.rglob("*")
        source = PY_DIR.rglob("*")
        for item in source:
            if not item.is_file():
                continue
            #
            comm_files.append(str(item))
    else:
        response = requests.get(FULL_API_LINK)
        data = response.json()
        #
        for item in data:
            if item["type"] != "file":
                continue
            #
            comm_files.append(item["name"])
    #
    return comm_files
