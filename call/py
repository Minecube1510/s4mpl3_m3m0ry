def resolve_target (comm_file):
    command_path = comm_file.replace(
        pyV["colon"], pyV["slash"])
    target_maps = [ f"{command_path}.py",
        command_path, ]
    #
    for target in target_maps:
        #print ((REDIC_LINK) + "/" + (target))
        #
        if PD_EXISTS:
            target_f = (REDIC_LINK / target)
            if target_f.exists():
                return target_f
        else:
            api_target = pyV["slash"].join([GIT_API_LINK,
                str(REPO_PY_DIR.as_posix()), target, ])
            api_target = pyV["quest"].join([
                api_target, LAST_PARAM, ])
            response = requests.get(api_target)
            #
            if response.status_code == 200:
                data = response.json()
                #
                return data["download_url"]
    return None
def execute_target(target_f, extra_args):
    # LOCAL #
    if PD_EXISTS:
        subprocess.run([ sys.executable,
            str(target_f), *extra_args,
        ], check=True)
        return
    #
    # REMOTE #
    response = requests.get(target_f)
    if response.status_code != 200:
        print("Failed download target...")
        return
    #
    with tempfile.NamedTemporaryFile(
        delete=False, suffix=".py",
        mode="w", encoding="utf-8"
    ) as temp_file:
        temp_file.write(response.text)
        temp_path = temp_file.name
    #
    env = os.environ.copy()
    env["ROOT_DIR"] = str(ROOT_DIR.resolve())
    env["PYTHONPATH"] = ((str(PLUGIN_FUNC))
        + (os.pathsep) + (str(PY_DIR)))
    #
    subprocess.run([ sys.executable,
        temp_path, *extra_args,
    ], env=env, check=True, )
